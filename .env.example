# Copy values into .env or .env.local. These files are gitignored.

# Jira Data Center / company Jira PAT auth.
AURA_JIRA_BASE_URL=https://jira.example.com
AURA_JIRA_TOKEN=
# Alias for AURA_JIRA_TOKEN. Set one or the other, not both.
AURA_JIRA_PAT=
AURA_JIRA_DEFAULT_PROJECT=

# Microsoft Teams Workflows webhook notification.
# Create a Teams Workflows webhook and paste the generated URL here.
AURA_TEAMS_WEBHOOK_URL=
# Set to 0/false/no/off to disable automatic test-completion notifications.
AURA_TEAMS_NOTIFY_ON_COMPLETE=1

# Optional aura runtime settings.
AURA_MODEL=claude-opus-4.6
AURA_SSH_USE_AGENT=0
# Optional SSH password fallback. Prefer scoped variables over the global one
# when multiple systems use different passwords. Scoped suffix is normalized
# from credential_id, or from username@host when credential_id is omitted.
# Examples: credential_id "bench-a" -> AURA_SSH_PASSWORD_BENCH_A
#           root@192.168.1.10 -> AURA_SSH_PASSWORD_ROOT_192_168_1_10
AURA_SSH_PASSWORD=
AURA_SSH_PASSWORD_BENCH_A=
AURA_IDLE_TIMEOUT_MS=

# Optional default spreadsheet for --agentic planning.
# Path can be repo-relative or an absolute local path. Sheet is optional for .xlsx files.
AURA_AGENTIC_SPREADSHEET_PATH=
AURA_AGENTIC_SPREADSHEET_SHEET=

# Optional agentic executor progress controls.
# Poll frequency controls how often Aura checks run state.
AURA_AGENTIC_POLL_WAIT_MS=2000
# Quiet heartbeat controls how often Aura reports that a run is still active
# when no new output chunk has arrived. Set 0 to disable quiet heartbeats.
AURA_AGENTIC_PROGRESS_HEARTBEAT_MS=30000
# Output chunk size controls how many output lines make one progress update.
AURA_AGENTIC_PROGRESS_CHUNK_LINES=20
