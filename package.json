{
  "name": "aura-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TUI-first personal test-running agent built on the GitHub Copilot SDK",
  "bin": {
    "aura": "./src/index.tsx"
  },
  "scripts": {
    "start": "tsx src/index.tsx",
    "dev": "tsx watch src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.8",
    "env-paths": "^4.0.0",
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "ssh2": "^1.17.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.0",
    "@types/ssh2": "^1.15.5",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
